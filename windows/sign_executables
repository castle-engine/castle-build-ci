#!/bin/bash
set -euo pipefail

# -----------------------------------------------------------------------------
# Sign executables (given on command line) with Azure Artifact Signing.
# Multiple files can be provided as parameters on command line, to sign at once.
# Provide directory to find all *.exe and *.dll inside it (recursively).
# See README.md for more details.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------
# Adjust MSys2, in case this runs inside MSys2 (like in GitHub Actions runner).

# Avoid MSys2 path conversion, as we pass parameters that look like Unix paths.
# See castle-engine/.github/workflows/use_cygpath_not_msys_automatic_conversions.md
# for explanation.
export MSYS2_ENV_CONV_EXCL='*'
export MSYS2_ARG_CONV_EXCL='*'
export MSYS_NO_PATHCONV=1

# -----------------------------------------------------------------------
# Validate necessary environment variables are set, files exist, etc.

# env vars not empty
if [ -z "${AZURE_SIGNING_CLIENT_PARENT:-}" ]; then
  echo "AZURE_SIGNING_CLIENT_PARENT environment variable is not set. Please set it to the parent directory of Microsoft.ArtifactSigning.Client."
  exit 1
fi
if [ -z "${AZURE_ENDPOINT:-}" ]; then
  echo "AZURE_ENDPOINT environment variable is not set. Please set it to the Azure endpoint."
  exit 1
fi
if [ -z "${AZURE_CODESIGNING_ACCOUNT_NAME:-}" ]; then
  echo "AZURE_CODESIGNING_ACCOUNT_NAME environment variable is not set. Please set it to the Azure code signing account name."
  exit 1
fi
if [ -z "${AZURE_CERTIFICATE_PROFILE_NAME:-}" ]; then
  echo "AZURE_CERTIFICATE_PROFILE_NAME environment variable is not set. Please set it to the Azure certificate profile name."
  exit 1
fi

# calculate ARTIFACT_SIGNING_DLL, and make sure it (along with AZURE_SIGNING_CLIENT_PARENT)
# is valid
ARTIFACT_SIGNING_DLL="${AZURE_SIGNING_CLIENT_PARENT}/Microsoft.ArtifactSigning.Client/bin/x64/Azure.CodeSigning.Dlib.dll"
if [ ! -f "${ARTIFACT_SIGNING_DLL}" ]; then
  echo "Artifact Signing DLL not found at expected location: ${ARTIFACT_SIGNING_DLL}"
  exit 1
fi

# at least one parameter (file to sign) is provided
[ $# -ge 1 ] || {
  echo "Usage: $0 file.exe [file2.dll ...]"
  exit 1;
}

# ------------------------------------------------------------------------
# Find $SIGNTOOL, the latest version of signtool.exe from Windows SDK.

# Glob the SDK version subdirectory (like 10.0.28000.0), to not depend on
# the exact SDK version; take the latest if multiple are installed.
# Note: Artifact Signing requires SignTool >= 10.0.2261.
PROGRAM_FILES_X86="$(cygpath "$(printenv 'ProgramFiles(x86)')")"

shopt -s nullglob
SIGNTOOL_CANDIDATES=("${PROGRAM_FILES_X86}/Windows Kits/10/bin/"10.*"/x64/signtool.exe")
shopt -u nullglob

if [ "${#SIGNTOOL_CANDIDATES[@]}" -eq 0 ]; then
  echo "signtool.exe not found, tried: ${PROGRAM_FILES_X86}/Windows Kits/10/bin/10.*/x64/signtool.exe"
  exit 1
fi

SIGNTOOL="$(printf '%s\n' "${SIGNTOOL_CANDIDATES[@]}" | sort --version-sort | tail -n 1)"
echo "Using SignTool: ${SIGNTOOL}"

# -----------------------------------------------------------------------------
# Calculate FILES_TO_SIGN bash array with filenames.

FILES_TO_SIGN=()
for F in "$@"; do
  if [[ -d "$F" ]]; then
    shopt -s nullglob globstar nocaseglob
    for FILE in "$F"/**/*.exe "$F"/**/*.dll; do
      FILES_TO_SIGN+=("$FILE")
    done
    shopt -u nullglob globstar nocaseglob
  else
    FILES_TO_SIGN+=("$F")
  fi
done

if [ "${#FILES_TO_SIGN[@]}" -eq 0 ]; then
  echo "No files to sign (checked parameters: $*)"
  exit 1
fi

echo "Files to sign: ${FILES_TO_SIGN[*]}"

# ------------------------------------------------------------------------
# signing

# calculate AZURE_SIGNING_METADATA location (in temp dir)
if [ -n "${RUNNER_TEMP:-}" ]; then
  AZURE_SIGNING_METADATA="${RUNNER_TEMP}/azure_signing_metadata.json"
else
  AZURE_SIGNING_METADATA="$(mktemp -t azure_signing_metadata.XXXXXX.json)"
  if which cygpath > /dev/null; then
    AZURE_SIGNING_METADATA="$(cygpath --mixed "${AZURE_SIGNING_METADATA}")"
  fi
fi

# create AZURE_SIGNING_METADATA contents
cat > "${AZURE_SIGNING_METADATA}" <<EOF
{
  "Endpoint": "https://${AZURE_ENDPOINT}",
  "CodeSigningAccountName": "${AZURE_CODESIGNING_ACCOUNT_NAME}",
  "CertificateProfileName": "${AZURE_CERTIFICATE_PROFILE_NAME}"
}
EOF

# execute signtool
# (single invocation for multiple files)
"${SIGNTOOL}" sign /v /debug /fd SHA256 \
  /tr "http://timestamp.acs.microsoft.com" \
  /td SHA256 \
  /dlib "${ARTIFACT_SIGNING_DLL}" \
  /dmdf "${AZURE_SIGNING_METADATA}" \
  "${FILES_TO_SIGN[@]}"

echo "Signing completed successfully."

echo "------------------------------------------------------------------"
echo "Verifying by SignTool..."

# Use
#   $SignTool verify /?
# to explain options.
"${SIGNTOOL}" verify /pa /v /tw "${FILES_TO_SIGN[@]}"

echo "------------------------------------------------------------------"
echo "Verifying by Get-AuthenticodeSignature..."

# Check signature details without SignTool (useful on other machines)
for F in "${FILES_TO_SIGN[@]}"; do
  powershell.exe -NoProfile -Command "Get-AuthenticodeSignature '$F' | Format-List"
done

echo "------------------------------------------------------------------"
echo "Done."
